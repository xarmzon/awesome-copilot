{
  "name": "modernize-java",
  "version": "1.0.0",
  "description": "AI-powered Java modernization and upgrade assistant. Helps upgrade Java and Spring Boot applications to the latest versions.",
  "author": {
    "name": "Microsoft"
  },
  "keywords": [
    "java",
    "modernization",
    "upgrade",
    "migration",
    "spring-boot"
  ],
  "license": "MIT",
  "agents": [
    "./agents"
  ],
  "mcpServers": {
    "appmod-mcp-server": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/github-copilot-app-modernization-mcp-server"
      ]
    }
  }
}
